{
  "name": "@word-forge/schemas",
  "version": "1.0.4",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsdown && mv dist/index.d.mts dist/index.d.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  }
}